<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.autotrading</groupId>
  <artifactId>autotrading-implementation</artifactId>
  <version>0.1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <name>autotrading-implementation</name>
  <description>Paper vertical slice implementation monorepo</description>

  <modules>
    <module>libs/contracts</module>
    <module>libs/reliability-core</module>
    <module>libs/kafka-client</module>
    <module>services/ingress-gateway-service</module>
    <module>services/event-processor-service</module>
    <module>services/agent-runtime-service</module>
    <module>services/risk-service</module>
    <module>services/order-service</module>
    <module>services/ibkr-connector-service</module>
    <module>services/performance-service</module>
    <module>services/monitoring-api</module>
    <module>tests/e2e</module>
  </modules>

  <properties>
    <java.version>21</java.version>
    <maven.compiler.release>${java.version}</maven.compiler.release>
    <spring-boot.version>3.3.5</spring-boot.version>
    <grpc.version>1.66.0</grpc.version>
    <protobuf.version>3.25.3</protobuf.version>
    <junit.version>5.11.3</junit.version>
    <jacoco.version>0.8.14</jacoco.version>
    <coverage.minimum.line>0.50</coverage.minimum.line>
    <coverage.check.skip>true</coverage.check.skip>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <!-- empty default; JaCoCo prepare-agent appends to this at runtime -->
    <argLine></argLine>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-dependencies</artifactId>
        <version>${spring-boot.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>io.grpc</groupId>
        <artifactId>grpc-bom</artifactId>
        <version>${grpc.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
      <dependency>
        <groupId>org.junit</groupId>
        <artifactId>junit-bom</artifactId>
        <version>${junit.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <build>
    <pluginManagement>
      <plugins>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-compiler-plugin</artifactId>
          <version>3.13.0</version>
          <configuration>
            <release>${maven.compiler.release}</release>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.apache.maven.plugins</groupId>
          <artifactId>maven-surefire-plugin</artifactId>
          <version>3.5.2</version>
          <configuration>
            <useModulePath>false</useModulePath>
            <!-- Required for Mockito inline mock maker on Java 17+:
                 allows ByteBuddy to instrument java.base interfaces like AutoCloseable.
                 ${argLine} is populated by JaCoCo prepare-agent when the coverage
                 profile is active; defaults to empty string otherwise. -->
            <argLine>
              ${argLine}
              --add-opens java.base/java.lang=ALL-UNNAMED
              --add-opens java.base/java.util=ALL-UNNAMED
              --add-opens java.base/java.io=ALL-UNNAMED
              -XX:+EnableDynamicAgentLoading
            </argLine>
          </configuration>
        </plugin>
        <plugin>
          <groupId>org.springframework.boot</groupId>
          <artifactId>spring-boot-maven-plugin</artifactId>
          <version>${spring-boot.version}</version>
        </plugin>
        <plugin>
          <groupId>org.jacoco</groupId>
          <artifactId>jacoco-maven-plugin</artifactId>
          <version>${jacoco.version}</version>
        </plugin>
      </plugins>
    </pluginManagement>
  </build>

  <profiles>
    <profile>
      <id>coverage-core</id>
      <build>
        <plugins>
          <plugin>
            <groupId>org.jacoco</groupId>
            <artifactId>jacoco-maven-plugin</artifactId>
            <executions>
              <execution>
                <id>prepare-agent</id>
                <goals>
                  <goal>prepare-agent</goal>
                </goals>
              </execution>
              <execution>
                <id>report</id>
                <phase>verify</phase>
                <goals>
                  <goal>report</goal>
                </goals>
              </execution>
              <execution>
                <id>check</id>
                <phase>verify</phase>
                <goals>
                  <goal>check</goal>
                </goals>
                <configuration>
                  <skip>${coverage.check.skip}</skip>
                  <excludes>
                    <!-- Spring Boot entry points -->
                    <exclude>**/*Application.class</exclude>
                    <!-- Generated gRPC/protobuf stubs -->
                    <exclude>**/*Grpc.class</exclude>
                    <exclude>**/*Grpc$*.class</exclude>
                    <exclude>**/*Proto*.class</exclude>
                    <exclude>**/*OuterClass*.class</exclude>
                    <exclude>**/*OrBuilder.class</exclude>
                    <!-- Spring wiring: @Configuration + @AutoConfiguration beans
                         contain bean factory methods only — no business logic -->
                    <exclude>**/*Configuration.class</exclude>
                    <exclude>**/*AutoConfiguration.class</exclude>
                    <!-- JDBC/Kafka infrastructure: requires DB+Kafka integration
                         tests; covered by e2e suite, not unit coverage -->
                    <exclude>**/Jdbc*.class</exclude>
                    <exclude>**/KafkaOutbox*.class</exclude>
                  </excludes>
                  <rules>
                    <rule>
                      <element>BUNDLE</element>
                      <limits>
                        <limit>
                          <counter>LINE</counter>
                          <value>COVEREDRATIO</value>
                          <minimum>${coverage.minimum.line}</minimum>
                        </limit>
                      </limits>
                    </rule>
                  </rules>
                </configuration>
              </execution>
            </executions>
          </plugin>
        </plugins>
      </build>
    </profile>
  </profiles>
</project>
