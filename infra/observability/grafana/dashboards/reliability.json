{
  "id": null,
  "uid": "autotrading-reliability",
  "title": "Autotrading Reliability",
  "tags": ["autotrading", "reliability"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "First-Status Timeout Count",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sum(autotrading_reliability_first_status_timeout_count) or vector(0)",
          "legendFormat": "timeout count",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Outbox Backlog Age (ms)",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 60000 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "max(autotrading_reliability_outbox_backlog_age_ms) or vector(0)",
          "legendFormat": "backlog age ms",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Duplicate Suppression Count",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "sum(autotrading_reliability_duplicate_suppression_count) or vector(0)",
          "legendFormat": "suppression count",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reliability Metrics Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "uid": "prometheus", "type": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum(autotrading_reliability_first_status_timeout_count) or vector(0)",
          "legendFormat": "first-status timeouts",
          "refId": "A"
        },
        {
          "expr": "max(autotrading_reliability_outbox_backlog_age_ms) or vector(0)",
          "legendFormat": "outbox backlog age ms",
          "refId": "B"
        },
        {
          "expr": "sum(autotrading_reliability_duplicate_suppression_count) or vector(0)",
          "legendFormat": "duplicate suppression count",
          "refId": "C"
        }
      ]
    }
  ]
}
