{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plan Sync Tasks",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "title",
          "epic",
          "owner_team",
          "service",
          "status",
          "risk_tier",
          "acceptance_criteria",
          "release_tag"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^ATP-[A-Z0-9]+$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "epic": {
            "type": "string",
            "minLength": 3
          },
          "owner_team": {
            "type": "string",
            "minLength": 2
          },
          "service": {
            "type": "string",
            "minLength": 2
          },
          "status": {
            "type": "string",
            "enum": ["BACKLOG", "READY", "IN_PROGRESS", "IN_REVIEW", "QA", "DONE", "DEPRECATED"]
          },
          "risk_tier": {
            "type": "string",
            "enum": ["P0", "P1", "P2", "P3"]
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "evidence_url": {
            "type": "string"
          },
          "release_tag": {
            "type": "string",
            "minLength": 1
          },
          "deprecatedReason": {
            "type": "string"
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
