{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrading/contracts/schemas/policy.evaluations.audit.v1.json",
  "title": "policy.evaluations.audit.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "trace_id",
    "agent_id",
    "instrument_id",
    "signal_id",
    "decision",
    "policy_version",
    "policy_rule_set",
    "matched_rule_ids",
    "deny_reasons",
    "failure_mode",
    "latency_ms",
    "source_system"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "const": "policy.evaluations.audit"
    },
    "event_version": {
      "type": "integer",
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "instrument_id": {
      "type": "string",
      "minLength": 1
    },
    "signal_id": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "DENY"]
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "policy_rule_set": {
      "type": "string",
      "minLength": 1
    },
    "matched_rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_mode": {
      "type": "string",
      "enum": [
        "NONE",
        "OPA_TIMEOUT",
        "OPA_UNAVAILABLE",
        "OPA_SCHEMA_ERROR",
        "BUNDLE_LOAD_ERROR"
      ]
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "source_system": {
      "type": "string",
      "const": "risk-service"
    }
  }
}
