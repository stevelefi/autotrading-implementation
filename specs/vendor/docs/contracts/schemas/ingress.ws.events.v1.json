{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrading/contracts/schemas/ingress.ws.events.v1.json",
  "title": "ingress.ws.events.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "trace_id", "ts"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "event.submit",
        "event.accepted",
        "event.validation_failed",
        "event.routed",
        "event.failed"
      ]
    },
    "trace_id": {
      "type": "string",
      "format": "uuid"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "ingress_event_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["ACCEPTED", "VALIDATION_FAILED", "ROUTED", "FAILED"]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object"
        }
      }
    },
    "payload": {
      "type": "object"
    }
  }
}
