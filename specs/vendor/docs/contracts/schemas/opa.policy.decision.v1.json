{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autotrading/contracts/schemas/opa.policy.decision.v1.json",
  "title": "opa.policy.decision.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "allow",
    "deny_reasons",
    "matched_rule_ids",
    "failure_mode",
    "applied_policy_version",
    "applied_rule_set"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "opa.policy.decision.v1"
    },
    "allow": {
      "type": "boolean"
    },
    "deny_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "matched_rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_mode": {
      "type": "string",
      "enum": [
        "NONE",
        "OPA_TIMEOUT",
        "OPA_UNAVAILABLE",
        "OPA_SCHEMA_ERROR",
        "BUNDLE_LOAD_ERROR"
      ]
    },
    "applied_policy_version": {
      "type": "string",
      "minLength": 1
    },
    "applied_rule_set": {
      "type": "string",
      "minLength": 1
    }
  }
}
